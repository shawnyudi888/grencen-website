<section style="padding:3rem 1.5rem;max-width:1000px;margin:0 auto;"><h1 style="font-size:2rem;font-weight:600;color:var(--color-deepgreen);margin-bottom:2rem;font-family:'Playfair Display',serif;">Shopping Cart</h1>{% if cart.item_count > 0 %}<form action="/cart" method="post"><div style="display:flex;flex-direction:column;gap:1.5rem;margin-bottom:2rem;">{% for item in cart.items %}<div style="display:grid;grid-template-columns:100px 1fr auto;gap:1.5rem;padding:1.5rem;border:1px solid var(--color-warmgray);border-radius:0.5rem;align-items:center;"><img src="{{ item.image | img_url: '200x200' }}" alt="{{ item.title }}" style="width:100px;height:100px;object-fit:cover;border-radius:0.375rem;"><div><h3 style="font-weight:600;color:var(--color-deepgreen);margin-bottom:0.5rem;">{{ item.product.title }}</h3><p style="color:var(--color-warmgray);font-size:0.875rem;margin-bottom:0.5rem;">${{ item.price | money_without_currency }} each</p><div style="display:flex;align-items:center;gap:0.5rem;"><input type="number" name="updates[]" value="{{ item.quantity }}" min="0" style="width:60px;padding:0.5rem;border:1px solid var(--color-warmgray);border-radius:0.375rem;"></div></div><div style="text-align:right;"><p style="font-weight:600;color:var(--color-sage);font-size:1.125rem;">${{ item.line_price | money_without_currency }}</p></div></div>{% endfor %}</div><div style="border-top:2px solid var(--color-warmgray);padding-top:1.5rem;"><div style="display:flex;justify-content:space-between;margin-bottom:1rem;"><span style="font-size:1.25rem;font-weight:600;color:var(--color-deepgreen);">Subtotal:</span><span style="font-size:1.25rem;font-weight:600;color:var(--color-sage);">${{ cart.total_price | money_without_currency }}</span></div><button type="submit" name="update" style="width:100%;background:var(--color-warmgray);color:white;padding:0.75rem;border:none;border-radius:0.375rem;font-weight:600;margin-bottom:1rem;">Update Cart</button><button type="submit" name="checkout" style="width:100%;background:var(--color-sage);color:white;padding:1rem;border:none;border-radius:0.375rem;font-weight:700;font-size:1.125rem;">Proceed to Checkout</button></div></form>{% else %}<p style="text-align:center;color:var(--color-warmgray);padding:3rem;">Your cart is empty. <a href="/collections/all" style="color:var(--color-sage);font-weight:600;">Continue shopping</a></p>{% endif %}</section>{% schema %}{"name":"Cart Page","settings":[]}{% endschema %}
