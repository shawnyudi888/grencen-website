<section style="padding:3rem 1.5rem;max-width:1280px;margin:0 auto;"><h2 style="font-size:2rem;font-weight:600;color:var(--color-deepgreen);text-align:center;margin-bottom:2rem;font-family:'Playfair Display',serif;">{{ section.settings.heading }}</h2><div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:1.5rem;">{% for block in section.blocks %}<a href="{{ block.settings.link }}" style="background:var(--color-cream);border:1px solid var(--color-warmgray);border-radius:0.5rem;padding:2rem 1rem;text-align:center;font-weight:500;color:var(--color-deepgreen);text-decoration:none;transition:border-color 0.2s;" onmouseover="this.style.borderColor='var(--color-sage)'" onmouseout="this.style.borderColor='var(--color-warmgray)'">{{ block.settings.title }}</a>{% endfor %}</div></section>{% schema %}{"name":"Category Grid","settings":[{"type":"text","id":"heading","label":"Heading","default":"Shop by Category"}],"blocks":[{"type":"category","name":"Category","settings":[{"type":"text","id":"title","label":"Category Name"},{"type":"url","id":"link","label":"Link"}]}],"presets":[{"name":"Category Grid","blocks":[{"type":"category","settings":{"title":"Hydrangeas","link":"/collections/hydrangeas"}},{"type":"category","settings":{"title":"Peonies","link":"/collections/peonies"}},{"type":"category","settings":{"title":"Wedding Flowers","link":"/collections/wedding"}}]}]}{% endschema %}
