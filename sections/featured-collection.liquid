<section style="padding:3rem 1.5rem;max-width:1280px;margin:0 auto;"><h2 style="font-size:2rem;font-weight:600;color:var(--color-deepgreen);text-align:center;margin-bottom:2rem;font-family:'Playfair Display',serif;">{{ section.settings.heading }}</h2><div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(250px,1fr));gap:2rem;">{% assign collection = collections[section.settings.collection] %}{% for product in collection.products limit:section.settings.products_to_show %}<a href="{{ product.url }}" style="text-decoration:none;border:1px solid var(--color-warmgray);border-radius:0.5rem;padding:1rem;display:block;transition:box-shadow 0.2s;"><img src="{{ product.featured_image | img_url: '400x400' }}" alt="{{ product.title }}" style="width:100%;height:200px;object-fit:cover;border-radius:0.375rem;margin-bottom:1rem;"><h3 style="font-size:1.125rem;font-weight:600;color:var(--color-deepgreen);margin-bottom:0.5rem;">{{ product.title }}</h3><p style="color:var(--color-sage);font-weight:600;">${{ product.price | money_without_currency }}</p></a>{% endfor %}</div></section>{% schema %}{"name":"Featured Collection","settings":[{"type":"text","id":"heading","label":"Heading","default":"Wedding / DIY Bouquet Kits"},{"type":"collection","id":"collection","label":"Collection"},{"type":"range","id":"products_to_show","min":2,"max":12,"step":1,"label":"Products to show","default":4}]}{% endschema %}
