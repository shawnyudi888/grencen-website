<section style="max-width:600px;margin:3rem auto;padding:2rem;border:1px solid var(--color-warmgray);border-radius:0.5rem;background:var(--color-cream);text-align:center;"><h3 style="font-size:1.5rem;font-weight:600;color:var(--color-deepgreen);margin-bottom:1rem;font-family:'Playfair Display',serif;">{{ section.settings.heading }}</h3><p style="color:var(--color-warmgray);margin-bottom:1.5rem;">{{ section.settings.subheading }}</p><form method="post" action="/contact#newsletter" accept-charset="UTF-8" class="newsletter-form" style="display:flex;flex-direction:column;gap:1rem;"><input type="hidden" name="form_type" value="customer"><input type="hidden" name="utf8" value="✓"><input type="hidden" name="contact[tags]" value="newsletter"><input type="email" name="contact[email]" placeholder="{{ section.settings.placeholder }}" required style="padding:0.75rem;border:1px solid var(--color-warmgray);border-radius:0.375rem;font-size:1rem;"><button type="submit" style="background:var(--color-sage);color:white;padding:0.75rem 1.5rem;border:none;border-radius:0.375rem;font-weight:600;cursor:pointer;">{{ section.settings.button_text }}</button></form></section>{% schema %}{"name":"Newsletter","settings":[{"type":"text","id":"heading","label":"Heading","default":"Join our Newsletter"},{"type":"textarea","id":"subheading","label":"Subheading","default":"Get exclusive styling tips and early access to new collections."},{"type":"text","id":"placeholder","label":"Email Placeholder","default":"you@example.com"},{"type":"text","id":"button_text","label":"Button Text","default":"Subscribe"}]}{% endschema %}
