<footer style="background:var(--color-cream);border-top:1px solid var(--color-warmgray);margin-top:5rem;padding:2.5rem 1.5rem;"><div style="max-width:1280px;margin:0 auto;display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:2rem;"><div><h4 style="color:var(--color-deepgreen);font-family:'Playfair Display',serif;margin-bottom:0.5rem;">{{ section.settings.col1_title }}</h4><p style="color:var(--color-warmgray);font-size:0.875rem;">{{ section.settings.col1_text }}</p></div><div><h4 style="color:var(--color-deepgreen);font-family:'Playfair Display',serif;margin-bottom:0.5rem;">Shop</h4><a href="/collections/all" style="display:block;color:var(--color-warmgray);font-size:0.875rem;margin:0.25rem 0;">Shop All</a><a href="/collections/best-sellers" style="display:block;color:var(--color-warmgray);font-size:0.875rem;margin:0.25rem 0;">Best Sellers</a><a href="/collections/wedding" style="display:block;color:var(--color-warmgray);font-size:0.875rem;margin:0.25rem 0;">Wedding</a></div><div><h4 style="color:var(--color-deepgreen);font-family:'Playfair Display',serif;margin-bottom:0.5rem;">Customer Care</h4><a href="/pages/faq" style="display:block;color:var(--color-warmgray);font-size:0.875rem;margin:0.25rem 0;">FAQ</a><a href="/pages/about" style="display:block;color:var(--color-warmgray);font-size:0.875rem;margin:0.25rem 0;">About</a><a href="/pages/contact" style="display:block;color:var(--color-warmgray);font-size:0.875rem;margin:0.25rem 0;">Contact</a></div><div><h4 style="color:var(--color-deepgreen);font-family:'Playfair Display',serif;margin-bottom:0.5rem;">Connect</h4><p style="color:var(--color-warmgray);font-size:0.875rem;">{{ section.settings.contact_email }}</p><p style="color:var(--color-warmgray);font-size:0.875rem;margin-top:1rem;">&copy; {{ "now" | date: "%Y" }} {{ shop.name }}</p></div></div></footer>{% schema %}{"name":"Footer","settings":[{"type":"text","id":"col1_title","label":"Column 1 Title","default":"Grencen"},{"type":"textarea","id":"col1_text","label":"Column 1 Text","default":"Premium realistic faux florals for homes, weddings, and events."},{"type":"text","id":"contact_email","label":"Contact Email","default":"support@grencen.com"}]}{% endschema %}
