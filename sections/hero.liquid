<section style="text-align:center;padding:3rem 1.5rem;max-width:900px;margin:0 auto;"><h1 style="font-size:2.5rem;font-weight:700;color:var(--color-deepgreen);margin-bottom:1rem;font-family:'Playfair Display',serif;">{{ section.settings.hero_title }}</h1><p style="color:var(--color-warmgray);font-size:1.125rem;margin-bottom:2rem;max-width:600px;margin-left:auto;margin-right:auto;">{{ section.settings.hero_subtitle }}</p><div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;"><a href="{{ section.settings.cta1_link }}" style="background:var(--color-sage);color:white;padding:0.75rem 1.5rem;border-radius:0.375rem;font-weight:600;text-decoration:none;display:inline-block;">{{ section.settings.cta1_text }}</a><a href="{{ section.settings.cta2_link }}" style="border:2px solid var(--color-sage);color:var(--color-sage);padding:0.75rem 1.5rem;border-radius:0.375rem;font-weight:600;text-decoration:none;display:inline-block;">{{ section.settings.cta2_text }}</a></div></section>{% schema %}{"name":"Hero","settings":[{"type":"text","id":"hero_title","label":"Title","default":"Realistic Faux Florals for Effortless Living"},{"type":"textarea","id":"hero_subtitle","label":"Subtitle","default":"Beautiful blooms with no watering, no wilting, and easy seasonal styling."},{"type":"text","id":"cta1_text","label":"Primary Button Text","default":"Shop Best Sellers"},{"type":"url","id":"cta1_link","label":"Primary Button Link","default":"/collections/best-sellers"},{"type":"text","id":"cta2_text","label":"Secondary Button Text","default":"Explore Wedding Kits"},{"type":"url","id":"cta2_link","label":"Secondary Button Link","default":"/collections/wedding"}]}{% endschema %}
