<section style="padding:3rem 1.5rem;max-width:1280px;margin:0 auto;"><div style="display:grid;grid-template-columns:1fr 1fr;gap:3rem;align-items:start;">{% if product.images.size > 0 %}<div><img src="{{ product.featured_image | img_url: '800x800' }}" alt="{{ product.title }}" style="width:100%;border-radius:0.5rem;"></div>{% endif %}<div><h1 style="font-size:2rem;font-weight:600;color:var(--color-deepgreen);margin-bottom:1rem;font-family:'Playfair Display',serif;">{{ product.title }}</h1><div style="display:flex;align-items:center;gap:1rem;margin-bottom:1.5rem;">{% if product.compare_at_price > product.price %}<span style="text-decoration:line-through;color:var(--color-warmgray);font-size:1.25rem;">${{ product.compare_at_price | money_without_currency }}</span>{% endif %}<span style="color:var(--color-sage);font-weight:700;font-size:1.5rem;">${{ product.price | money_without_currency }}</span></div><p style="color:var(--color-warmgray);margin-bottom:2rem;">{{ product.description }}</p><form action="/cart/add" method="post"><input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}"><div style="display:flex;gap:1rem;margin-bottom:1.5rem;"><input type="number" name="quantity" value="1" min="1" style="width:80px;padding:0.75rem;border:1px solid var(--color-warmgray);border-radius:0.375rem;"><button type="submit" style="flex:1;background:var(--color-sage);color:white;padding:0.75rem 1.5rem;border:none;border-radius:0.375rem;font-weight:600;font-size:1rem;">Add to Cart</button></div></form><div style="border-top:1px solid var(--color-warmgray);padding-top:1.5rem;"><p style="color:var(--color-warmgray);font-size:0.875rem;margin-bottom:0.5rem;">✓ Real-touch petals</p><p style="color:var(--color-warmgray);font-size:0.875rem;margin-bottom:0.5rem;">✓ Bendable stems</p><p style="color:var(--color-warmgray);font-size:0.875rem;margin-bottom:0.5rem;">✓ Ships flat for protection</p></div></div></div></section>{% schema %}{"name":"Product Page","settings":[]}{% endschema %}
