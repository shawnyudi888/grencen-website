<header style="background:var(--color-cream);border-bottom:1px solid var(--color-warmgray);position:sticky;top:0;z-index:50;"><div style="max-width:1280px;margin:0 auto;padding:1rem 1.5rem;display:flex;justify-content:space-between;align-items:center;"><a href="/" style="font-family:'Playfair Display',serif;font-size:1.5rem;font-weight:700;color:var(--color-deepgreen);text-decoration:none;">{{ section.settings.logo_text }}</a><nav style="display:none;" class="desktop-nav"><a href="/collections/all" style="margin:0 1rem;color:var(--color-warmgray);">Shop</a><a href="/collections/best-sellers" style="margin:0 1rem;color:var(--color-warmgray);">Best Sellers</a><a href="/collections/wedding" style="margin:0 1rem;color:var(--color-warmgray);">Wedding</a><a href="/pages/about" style="margin:0 1rem;color:var(--color-warmgray);">About</a><a href="/pages/faq" style="margin:0 1rem;color:var(--color-warmgray);">FAQ</a></nav><a href="/cart" style="color:var(--color-deepgreen);position:relative;"><svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 001.94-1.48L23 6H6"/></svg><span id="cart-count" style="position:absolute;top:-8px;right:-8px;background:var(--color-sage);color:white;border-radius:50%;width:20px;height:20px;display:flex;align-items:center;justify-content:center;font-size:0.75rem;">{{ cart.item_count }}</span></a></div></header>{% schema %}{"name":"Header","settings":[{"type":"text","id":"logo_text","label":"Logo Text","default":"Grencen"}]}{% endschema %}
