<section style="max-width:800px;margin:3rem auto;padding:0 1.5rem;"><h2 style="font-size:2rem;font-weight:600;color:var(--color-deepgreen);text-align:center;margin-bottom:2rem;font-family:'Playfair Display',serif;">{{ section.settings.heading }}</h2><div style="display:flex;flex-direction:column;gap:1.5rem;">{% for block in section.blocks %}<div><p style="font-weight:600;color:var(--color-deepgreen);margin-bottom:0.5rem;">{{ block.settings.question }}</p><p style="color:var(--color-warmgray);font-size:0.875rem;">{{ block.settings.answer }}</p></div>{% endfor %}</div><div style="text-align:center;margin-top:2rem;"><a href="{{ section.settings.faq_page }}" style="color:var(--color-sage);font-weight:600;text-decoration:underline;">View all FAQs</a></div></section>{% schema %}{"name":"FAQ Preview","settings":[{"type":"text","id":"heading","label":"Heading","default":"Frequently Asked Questions"},{"type":"url","id":"faq_page","label":"Full FAQ Page Link","default":"/pages/faq"}],"blocks":[{"type":"faq","name":"FAQ Item","settings":[{"type":"text","id":"question","label":"Question"},{"type":"textarea","id":"answer","label":"Answer"}]}],"presets":[{"name":"FAQ Preview","blocks":[{"type":"faq","settings":{"question":"How long does shipping take?","answer":"Shipping times vary by destination—typically 10-20 days."}},{"type":"faq","settings":{"question":"What if my flowers arrive damaged?","answer":"Contact us within 7 days with photos for replacement."}}]}]}{% endschema %}
