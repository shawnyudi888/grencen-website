<section style="padding:3rem 1.5rem;max-width:1280px;margin:0 auto;"><h1 style="font-size:2rem;font-weight:600;color:var(--color-deepgreen);margin-bottom:0.5rem;font-family:'Playfair Display',serif;">{{ collection.title }}</h1><p style="color:var(--color-warmgray);margin-bottom:2rem;">{{ collection.description }}</p><div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(250px,1fr));gap:2rem;">{% for product in collection.products %}{% render 'product-card', product: product %}{% endfor %}</div></section>{% schema %}{"name":"Collection Page","settings":[]}{% endschema %}
