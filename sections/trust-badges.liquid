<section style="display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:1.5rem;text-align:center;padding:2rem 1.5rem;max-width:1000px;margin:0 auto;"><div><p style="color:var(--color-warmgray);font-size:0.875rem;">{{ section.settings.badge1_text }}</p></div><div><p style="color:var(--color-warmgray);font-size:0.875rem;">{{ section.settings.badge2_text }}</p></div><div><p style="color:var(--color-warmgray);font-size:0.875rem;">{{ section.settings.badge3_text }}</p></div><div><p style="color:var(--color-warmgray);font-size:0.875rem;">{{ section.settings.badge4_text }}</p></div></section>{% schema %}{"name":"Trust Badges","settings":[{"type":"text","id":"badge1_text","label":"Badge 1","default":"30-day returns"},{"type":"text","id":"badge2_text","label":"Badge 2","default":"Damage replacement"},{"type":"text","id":"badge3_text","label":"Badge 3","default":"Trackable delivery"},{"type":"text","id":"badge4_text","label":"Badge 4","default":"Lightweight shipping"}]}{% endschema %}
